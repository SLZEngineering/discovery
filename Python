#!/usr/bin/env python3
"""
Generic Switch SNMP Pre-Deployment Discovery (Vendor-neutral) — APT install, no pip

This script is designed for managed on-prem switches (unknown/neutral vendors included) and uses standard SNMP MIBs:
- BRIDGE-MIB (dot1dTpFdbTable) for MAC table + port
- Q-BRIDGE-MIB (dot1qTpFdbTable) fallback for VLAN-aware MAC table (when dot1d is empty)
- IF-MIB for port names
- IP-MIB for ARP table (to map IP↔MAC) from the best ARP source
- LLDP-MIB for remote system name/description (often includes model)

Outputs:
- <prefix>_customer.csv (clean)
- <prefix>_debug.csv (includes confidence/reason/source/VLAN/ARP host used)

Dependencies (Ubuntu 24.04+ recommended approach):
  sudo apt-get update
  sudo apt-get install -y python3-yaml python3-pysnmp4

Optional tools for testing (not required by the script):
  sudo apt-get install -y snmp

Notes:
- pip is NOT required for this workflow.
- You do NOT need to enable an SNMP server/agent on the machine running this script.
  The script is an SNMP client and only needs outbound UDP/161 access to the switch/gateway.
"""

from __future__ import annotations

import argparse
import csv
import datetime as dt
import ipaddress
